<Window
    x:Class="DeskApp.PdfPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vista previa de PDF"
    Width="1000"
    Height="760"
    Closing="Window_Closing"
    Loaded="Window_Loaded"
    ResizeMode="CanResize"
    SizeChanged="Window_SizeChanged"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="10,10,10,6">
            <TextBlock
                x:Name="TitleTextBlock"
                VerticalAlignment="Center"
                FontSize="15"
                FontWeight="SemiBold"
                TextTrimming="CharacterEllipsis" />

            <StackPanel
                HorizontalAlignment="Right"
                DockPanel.Dock="Right"
                Orientation="Horizontal">
                <Button
                    x:Name="ZoomOutButton"
                    Width="34"
                    Margin="0,0,6,0"
                    Click="ZoomOutButton_Click"
                    Content="-" />
                <TextBlock
                    x:Name="ZoomTextBlock"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Text="100%" />
                <Button
                    x:Name="ZoomInButton"
                    Width="34"
                    Margin="0,0,12,0"
                    Click="ZoomInButton_Click"
                    Content="+" />

                <Button
                    x:Name="PrevPageButton"
                    Width="36"
                    Margin="0,0,6,0"
                    Click="PrevPageButton_Click"
                    Content="&lt;" />
                <TextBlock
                    x:Name="PageTextBlock"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Text="Pagina 0/0" />
                <Button
                    x:Name="NextPageButton"
                    Width="36"
                    Margin="0,0,10,0"
                    Click="NextPageButton_Click"
                    Content="&gt;" />

                <TextBox
                    x:Name="PageJumpTextBox"
                    Width="56"
                    Height="28"
                    Margin="0,0,6,0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    KeyDown="PageJumpTextBox_KeyDown" />
                <Button
                    x:Name="GoToPageButton"
                    Width="42"
                    Margin="0,0,12,0"
                    Click="GoToPageButton_Click"
                    Content="Ir" />

                <Button
                    x:Name="PrintButton"
                    Width="90"
                    Margin="0,0,12,0"
                    Click="PrintButton_Click"
                    Content="Imprimir" />

                <Button
                    Padding="10,4"
                    Click="CloseButton_Click"
                    Content="Cerrar" />
            </StackPanel>
        </DockPanel>

        <Border
            Grid.Row="1"
            Margin="10,0,10,10"
            Background="#F7F7F7"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Image
                        x:Name="PdfPageImage"
                        Margin="10"
                        HorizontalAlignment="Center"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Stretch="Uniform">
                        <Image.LayoutTransform>
                            <ScaleTransform x:Name="PdfScaleTransform" ScaleX="1" ScaleY="1" />
                        </Image.LayoutTransform>
                    </Image>
                </ScrollViewer>

                <Border
                    x:Name="LoadingOverlay"
                    Background="#80FFFFFF"
                    Visibility="Visible">
                    <StackPanel
                        Width="280"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <ProgressBar
                            x:Name="LoadingProgressBar"
                            Height="16"
                            Margin="0,0,0,10"
                            IsIndeterminate="True" />
                        <TextBlock
                            x:Name="StatusText"
                            FontSize="16"
                            Foreground="#666666"
                            Text="Cargando vista previa..."
                            TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
