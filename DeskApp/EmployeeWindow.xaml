<Window x:Class="DeskApp.EmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeskApp"
        mc:Ignorable="d"
        Title="EmployeeWindow"
        Height="700" 
        Width="1050"
        MinHeight="700" 
        MinWidth="1050"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActiveMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid>
                    <Image Stretch="UniformToFill" 
                           VerticalAlignment="Stretch" 
                           HorizontalAlignment="Stretch">
                        <Image.Source>
                            <BitmapImage UriSource="pack://application:,,,/Resources/bg-employee.png"/>
                        </Image.Source>
                    </Image>
                    <Rectangle Fill="Black" Opacity="0.6"/>
                </Grid>
            </Grid>
            <Grid Grid.Row="1" Background="White">
            </Grid>
        </Grid>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Centro de Administración" 
                       FontSize="36" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Foreground="White"
                       Margin="0,20"/>

            <Border Grid.Row="1" 
                    Background="#D9D9D9" 
                    CornerRadius="40"
                    Margin="10,10"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="10">
                        <Button x:Name="EmpleadosButton"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="MenuButton_Click"
                                Tag="Empleados"
                                Padding="5,10,15,10">
                            <Grid>
                                <Image Width="20"
                                       Height="20"
                                       HorizontalAlignment="Left"
                                       Margin="8,0,0,0"
                                       IsHitTestVisible="False">
                                    <Image.Source>
                                        <BitmapImage UriSource="pack://application:,,,/Resources/employee.png"/>
                                    </Image.Source>
                                </Image>
                                <TextBlock Text="Empleados"
                                           Padding="35,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Foreground="Black"/>
                            </Grid>
                        </Button>
                        <Button x:Name="ProductosButton"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="MenuButton_Click"
                                Tag="Productos"
                                Padding="5,10,15,10">
                            <Grid>
                                <Image Width="20"
                                       Height="20"
                                       HorizontalAlignment="Left"
                                       Margin="8,0,0,0"
                                       IsHitTestVisible="False">
                                    <Image.Source>
                                        <BitmapImage UriSource="pack://application:,,,/Resources/boxes.png"/>
                                    </Image.Source>
                                </Image>
                                <TextBlock Text="Productos"
                                           Padding="35,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Foreground="Black"/>
                            </Grid>
                        </Button>
                        <Button x:Name="ImpresorasButton"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="MenuButton_Click"
                                Tag="Impresoras"
                                Padding="5,10,15,10">
                            <Grid>
                                <Image Width="20"
                                       Height="20"
                                       HorizontalAlignment="Left"
                                       Margin="8,0,0,0"
                                       IsHitTestVisible="False">
                                    <Image.Source>
                                        <BitmapImage UriSource="pack://application:,,,/Resources/printer.png"/>
                                    </Image.Source>
                                </Image>
                                <TextBlock Text="Impresoras"
                                           Padding="35,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Foreground="Black"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3" 
                    Background="White" 
                    CornerRadius="20,20,20,20"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1,0,1,1">
                <Grid>
                    <Grid x:Name="Tab1Content" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Margin="0,10,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Lista de Empleados"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Margin="20,1"
                                       Foreground="#333333"/>
                            <Border Grid.Column="1"
                                    Height="40"
                                    CornerRadius="10"
                                    Background="#D9D9D9"
                                    Padding="3"
                                    HorizontalAlignment="Right">
                                <Grid>
                                    <TextBox x:Name="EmployeesSearchTextBox" 
                                             Padding="35,0,5,0"
                                             VerticalContentAlignment="Center"
                                             HorizontalAlignment="Stretch"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontSize="16"/>
                                    <TextBlock Text="Buscar"
                                               Padding="5,0,35,0"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               Foreground="#808080"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=EmployeesSearchTextBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="🔍"
                                               FontSize="18"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"
                                               Foreground="#808080"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <TextBlock Grid.Row="1"
                                   Text="Lista de Empleados"
                                   Margin="20,0,20,10"
                                   FontSize="12"
                                   Foreground="#333333"/>

                        <Border Grid.Row="2"
                                Background="#F9F9F9"
                                Margin="20,10"
                                CornerRadius="5"
                                Padding="10">
                            <DataGrid x:Name="EmployeesDataGrid"
                                      AutoGenerateColumns="False"
                                      ItemsSource="{Binding Users}"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#FFF7F7F7"
                                      RowBackground="White"
                                      GridLinesVisibility="None"
                                      Margin="0"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="N. empleado" Binding="{Binding IdUser}" Width="*"/>
                                    <DataGridTextColumn Header="Nombre" Binding="{Binding Names}" Width="*"/>
                                    <DataGridTextColumn Header="Apellido" Binding="{Binding Lastnames}" Width="*"/>
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                                    <DataGridTextColumn Header="Rol" Binding="{Binding Role}" Width="*"/>
                                    <DataGridTemplateColumn Header="Acciones" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Editar"
                                                        Padding="10,5"
                                                        Margin="5,0"
                                                        Tag="{Binding}"
                                                        Click="EditUser_Click"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- Tab 2: Nuevo -->
                    <Grid x:Name="Tab2Content" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="➕ Crear Nuevo"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="20"
                                   Foreground="#333333"/>

                        <Border Grid.Row="1" 
                                Background="#F9F9F9"
                                Margin="20"
                                CornerRadius="5"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Aquí irá el formulario de creación"
                                           FontSize="16"
                                           Foreground="#666666"/>
                                <TextBlock Text="• Campos de entrada"
                                           FontSize="14"
                                           Foreground="#888888"
                                           Margin="0,10,0,0"/>
                                <TextBlock Text="• Validaciones"
                                           FontSize="14"
                                           Foreground="#888888"/>
                                <TextBlock Text="• Botones de acción"
                                           FontSize="14"
                                           Foreground="#888888"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Tab 3: Estadísticas -->
                    <Grid x:Name="Tab3Content" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="📊 Estadísticas"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="20"
                                   Foreground="#333333"/>

                        <Border Grid.Row="1" 
                                Background="#F9F9F9"
                                Margin="20"
                                CornerRadius="5"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Aquí irán las estadísticas y gráficos"
                                           FontSize="16"
                                           Foreground="#666666"/>
                                <TextBlock Text="• Gráficos de datos"
                                           FontSize="14"
                                           Foreground="#888888"
                                           Margin="0,10,0,0"/>
                                <TextBlock Text="• Métricas importantes"
                                           FontSize="14"
                                           Foreground="#888888"/>
                                <TextBlock Text="• Análisis de tendencias"
                                           FontSize="14"
                                           Foreground="#888888"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Toast Notification Container -->
        <Grid x:Name="NotificationContainer" 
              IsHitTestVisible="False"
              VerticalAlignment="Top"
              HorizontalAlignment="Right"
              Margin="20"/>
    </Grid>
</Window>
