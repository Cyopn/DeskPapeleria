<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="DeskApp.CreateProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:DeskApp.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Crear Producto" 
        Height="720" 
        Width="700" 
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ObjectDataProvider x:Key="ItemCategories" 
                            MethodName="GetValues" 
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ItemCategory" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <Style TargetType="TextBox">
            <Setter Property="Background" 
                    Value="#D9D9D9"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Padding" 
                    Value="2,2"/>
            <Setter Property="FontSize" 
                    Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" 
                    Value="#D9D9D9"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Padding" 
                    Value="8,4"/>
            <Setter Property="FontSize" 
                    Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  Content="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Stretch"/>
                                <ToggleButton x:Name="ToggleButton" 
                                              Grid.Column="1" 
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent" 
                                              BorderThickness="0" 
                                              HorizontalContentAlignment="Center" 
                                              VerticalContentAlignment="Center" 
                                              Cursor="Hand" 
                                              OverridesDefaultStyle="True">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" 
                                                    BorderThickness="0">
                                                <Path Data="M 0 0 L 6 6 L 12 0 Z" 
                                                      Fill="#555" 
                                                      Stretch="Uniform" 
                                                      Width="12" 
                                                      Height="6" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>
                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" 
                                   Focusable="False" 
                                   PopupAnimation="None">
                                <Border Background="#D9D9D9" 
                                        CornerRadius="8 8 8 8" 
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                    <ScrollViewer Margin="0" 
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" 
                    Value="8,4"/>
            <Setter Property="FontSize" 
                    Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Crear Producto" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Margin="4" />
        <StackPanel Grid.Row="1" 
                    Margin="0,8,0,8">
            <StackPanel Orientation="Vertical" 
                        Margin="4" 
                        Width="660">
                <GroupBox Header="Articulo" 
                          Margin="0,8" 
                          FontWeight="Bold" 
                          FontSize="18">
                    <StackPanel Orientation="Vertical" 
                                Margin="6">
                        <StackPanel Orientation="Horizontal" 
                                    Margin="0,4">
                            <TextBlock Width="160" 
                                       FontWeight="Bold" 
                                       FontSize="17">Nombre:</TextBlock>
                            <TextBox x:Name="ItemNameTextBox" 
                                     Width="400" 
                                     FontSize="16"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" 
                                    Margin="0,4">
                            <TextBlock Width="160" 
                                       VerticalAlignment="Center" 
                                       FontWeight="Bold" 
                                       FontSize="18">Descripción:</TextBlock>
                            <TextBox x:Name="ProductDescriptionTextBox" 
                                     Width="400" 
                                     FontSize="16"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" 
                                    Margin="0,4">
                            <TextBlock Width="160" 
                                       VerticalAlignment="Center" 
                                       FontWeight="Bold" 
                                       FontSize="18">Precio:</TextBlock>
                            <TextBox x:Name="PriceTextBox" 
                                     Width="120" 
                                     FontSize="16"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" 
                                    Margin="0,4">
                            <TextBlock Width="160" 
                                       FontWeight="Bold" 
                                       FontSize="17">Disponible:</TextBlock>
                            <CheckBox x:Name="AvailableCheckBox" 
                                      FontSize="16"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" 
                                    Margin="0,4">
                            <TextBlock Width="160" 
                                       FontWeight="Bold" 
                                       FontSize="17">Categoria:</TextBlock>
                            <ComboBox x:Name="CategoryComboBox" 
                                      ItemsSource="{Binding Source={StaticResource ItemCategories}}" 
                                      Width="400" 
                                      FontSize="16"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="Imagen" 
                          Margin="0,8" 
                          FontWeight="Bold" 
                          FontSize="18">
                    <StackPanel>
                        <StackPanel Orientation="Vertical" 
                                    Margin="6">
                            <StackPanel Orientation="Horizontal" 
                                        Margin="0,4">
                                <TextBlock Width="160" 
                                           VerticalAlignment="Center" 
                                           FontWeight="Bold" 
                                           FontSize="18">Imagen:</TextBlock>
                                <Grid Width="400">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FileNameTextBox" 
                                             Width="280" 
                                             FontSize="16" 
                                             Grid.Column="0" 
                                             IsReadOnly="True"/>
                                    <Button Grid.Column="1" 
                                            Content="Cargar..." 
                                            Click="UploadButton_Click" 
                                            Width="110" 
                                            Margin="8,0,0,0" 
                                            Cursor="Hand"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Margin="0,4">
                                <Border Margin="8,0,0,0" 
                                        Background="#EEE" 
                                        CornerRadius="6" 
                                        Width="200" 
                                        Height="200">
                                    <Grid>
                                        <Image x:Name="PreviewImage" 
                                               Stretch="Uniform" 
                                               Width="200" 
                                               Height="200"/>
                                        <Button x:Name="AdjustButton" 
                                                Content="Ajustar" 
                                                Width="90" 
                                                Height="32" 
                                                HorizontalAlignment="Center" 
                                                VerticalAlignment="Center" 
                                                Background="Transparent" 
                                                Margin="0,6,6,0" 
                                                Click="AdjustButton_Click" 
                                                Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,8,4,4">
            <Button Content="Cancelar" 
                    Width="100" 
                    Click="CancelButton_Click" 
                    Background="Black" 
                    Foreground="White" 
                    FontSize="18" 
                    Cursor="Hand"/>
            <Button x:Name="CreateButton" 
                    Content="Crear" 
                    Width="100" 
                    Margin="8,0,0,0" 
                    Click="CreateButton_Click" 
                    FontSize="18" 
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>