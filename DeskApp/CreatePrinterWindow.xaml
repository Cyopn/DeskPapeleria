<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="DeskApp.CreatePrinterWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="Agregar impresora"
    Width="700"
    Height="750"
    Closed="Window_Closed"
    Loaded="Window_Loaded"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9D9D9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2,2" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,8"
            FontWeight="Bold"
            Text="Escaneo automático de impresoras (red y locales)" />
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,8"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <StackPanel
                x:Name="ScanningPanel"
                Margin="0,0,12,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <ProgressBar
                    Width="120"
                    Height="16"
                    VerticalAlignment="Center"
                    IsIndeterminate="True" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontStyle="Italic"
                    Foreground="#444"
                    Text="  Escaneando..." />
            </StackPanel>
            <TextBlock
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Style="{StaticResource LabelTextStyle}">
                Impresoras detectadas:
            </TextBlock>
            <Border
                Width="360"
                Padding="6,3"
                Background="#D9D9D9"
                CornerRadius="10">
                <ComboBox
                    x:Name="PrintersComboBox"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    DisplayMemberPath="Name"
                    FontSize="14"
                    SelectionChanged="PrintersComboBox_SelectionChanged" />
            </Border>
        </StackPanel>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="83*" />
                <ColumnDefinition Width="597*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Margin="0,0,0,8"
                Orientation="Vertical">
                <TextBlock Style="{StaticResource LabelTextStyle}">Nombre:</TextBlock>
                <TextBox x:Name="NameTextBox" IsReadOnly="True" />
            </StackPanel>
            <StackPanel
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,0,0,8"
                Orientation="Vertical">
                <TextBlock Style="{StaticResource LabelTextStyle}">Tipo:</TextBlock>
                <Border
                    Padding="6,3"
                    Background="#D9D9D9"
                    CornerRadius="10">
                    <ComboBox
                        x:Name="TypeComboBox"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="14"
                        IsEnabled="False"
                        SelectedIndex="0">
                        <sys:String>Unknown</sys:String>
                        <sys:String>Usb</sys:String>
                        <sys:String>Network</sys:String>
                        <sys:String>Installed</sys:String>
                    </ComboBox>
                </Border>
            </StackPanel>
            <StackPanel
                Grid.Row="1"
                Grid.RowSpan="2"
                Grid.ColumnSpan="2"
                Margin="0,58,0,8"
                Orientation="Vertical">
                <TextBlock Style="{StaticResource LabelTextStyle}">IP:</TextBlock>
                <TextBox x:Name="IpTextBox" IsReadOnly="True" />
            </StackPanel>
            <StackPanel
                Grid.Row="3"
                Grid.ColumnSpan="2"
                Margin="0,0,0,8"
                Orientation="Vertical">
                <TextBlock Style="{StaticResource LabelTextStyle}">Puerto (numérico):</TextBlock>
                <TextBox x:Name="PortTextBox" IsReadOnly="True" />
                <TextBlock Margin="0,6,0,0" Style="{StaticResource LabelTextStyle}">Puerto (raw - e.g. USB001, IP_192.168.x.x):</TextBlock>
                <TextBox x:Name="PortNameTextBox" IsReadOnly="True" />
                <TextBlock Margin="0,6,0,0" Style="{StaticResource LabelTextStyle}">Modelo:</TextBlock>
                <TextBox x:Name="ModelTextBox" IsReadOnly="True" />
                <TextBlock Margin="0,6,0,0" Style="{StaticResource LabelTextStyle}">Driver:</TextBlock>
                <TextBox x:Name="DriverTextBox" IsReadOnly="True" />
            </StackPanel>
            <StackPanel
                Grid.Row="4"
                Grid.ColumnSpan="2"
                Margin="0,0,0,8"
                Orientation="Vertical">
                <TextBlock Style="{StaticResource LabelTextStyle}">Serial:</TextBlock>
                <TextBox x:Name="SerialTextBox" IsReadOnly="True" />
                <TextBlock Margin="0,6,0,0" Style="{StaticResource LabelTextStyle}">MAC:</TextBlock>
                <TextBox x:Name="MacTextBox" IsReadOnly="True" />
            </StackPanel>
            <StackPanel
                Grid.Row="4"
                Grid.RowSpan="2"
                Grid.ColumnSpan="2"
                Margin="0,115,0,8"
                Orientation="Vertical">
                <TextBlock Style="{StaticResource LabelTextStyle}">Estatus:</TextBlock>
                <Border
                    Padding="6,3"
                    Background="#D9D9D9"
                    CornerRadius="10">
                    <ComboBox
                        x:Name="StatusComboBox"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="14"
                        IsEnabled="False"
                        SelectedIndex="0">
                        <sys:String>Available</sys:String>
                        <sys:String>Busy</sys:String>
                        <sys:String>Offline</sys:String>
                    </ComboBox>
                </Border>
            </StackPanel>
        </Grid>
        <StackPanel
            Grid.Row="3"
            Margin="0,8,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="90"
                Margin="0,0,8,0"
                Click="SavePrinter_Click"
                Content="Guardar" />
            <Button
                Width="160"
                Margin="0,0,8,0"
                Click="PrintTest_Click"
                Content="Imprimir prueba" />
            <Button
                Width="90"
                Click="CloseButton_Click"
                Content="Cerrar" />
        </StackPanel>
    </Grid>
</Window>
