<Window
    x:Class="DeskApp.TransactionSearchSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Configurar busqueda"
    Width="420"
    Height="210"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,10"
            FontSize="16"
            FontWeight="SemiBold"
            Text="Buscar solo en la columna:" />

        <Border
            Grid.Row="1"
            Height="35"
            Padding="6,3"
            Background="#D9D9D9"
            CornerRadius="10">
            <ComboBox
                x:Name="SearchFieldComboBox"
                VerticalContentAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                FontSize="15">
                <ComboBoxItem Content="Todas" Tag="all" />
                <ComboBoxItem Content="ID transaccion" Tag="id_transaction" />
                <ComboBoxItem Content="ID usuario" Tag="id_user" />
                <ComboBoxItem Content="Tipo" Tag="type" />
                <ComboBoxItem Content="Fecha" Tag="date" />
                <ComboBoxItem Content="Usuario" Tag="user" />
                <ComboBoxItem Content="Total" Tag="total" />
                <ComboBoxItem Content="Estado" Tag="status" />
            </ComboBox>
        </Border>

        <StackPanel
            Grid.Row="3"
            Margin="0,12,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Margin="0,0,8,0"
                Click="CancelButton_Click"
                Content="Cancelar" />
            <Button
                Width="100"
                Click="ApplyButton_Click"
                Content="Aplicar" />
        </StackPanel>
    </Grid>
</Window>
