<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="DeskApp.ImageEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Editor de Imagen"
    Width="800"
    Height="600"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Border
                Padding="8"
                Background="#222"
                ClipToBounds="True"
                CornerRadius="8">
                <Grid ClipToBounds="True">
                    <Image x:Name="EditorImage" Stretch="Uniform" />
                    <Canvas
                        x:Name="OverlayCanvas"
                        Width="{Binding ActualWidth, ElementName=EditorImage}"
                        Height="{Binding ActualHeight, ElementName=EditorImage}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        ClipToBounds="True"
                        IsHitTestVisible="True">
                        <Rectangle
                            x:Name="CropRect"
                            Canvas.Left="0"
                            Canvas.Top="0"
                            Width="100"
                            Height="100"
                            Cursor="Hand"
                            Fill="#40FFFFFF"
                            IsHitTestVisible="False"
                            Stroke="#FF4080"
                            StrokeThickness="2"
                            Visibility="Visible" />
                        <Line
                            x:Name="GridLineV1"
                            Stroke="#80FFFFFF"
                            StrokeThickness="1"
                            Visibility="Visible" />
                        <Line
                            x:Name="GridLineV2"
                            Stroke="#80FFFFFF"
                            StrokeThickness="1"
                            Visibility="Visible" />
                        <Line
                            x:Name="GridLineH1"
                            Stroke="#80FFFFFF"
                            StrokeThickness="1"
                            Visibility="Visible" />
                        <Line
                            x:Name="GridLineH2"
                            Stroke="#80FFFFFF"
                            StrokeThickness="1"
                            Visibility="Visible" />
                        <Thumb
                            x:Name="TopLeftThumb"
                            Width="12"
                            Height="12"
                            Background="#FF4080"
                            Cursor="SizeNWSE" />
                        <Thumb
                            x:Name="TopRightThumb"
                            Width="12"
                            Height="12"
                            Background="#FF4080"
                            Cursor="SizeNESW" />
                        <Thumb
                            x:Name="BottomLeftThumb"
                            Width="12"
                            Height="12"
                            Background="#FF4080"
                            Cursor="SizeNESW" />
                        <Thumb
                            x:Name="BottomRightThumb"
                            Width="12"
                            Height="12"
                            Background="#FF4080"
                            Cursor="SizeNWSE" />
                    </Canvas>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Column="0"
                Margin="4"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Text="Rotación:" />
                <Slider
                    x:Name="RotationSlider"
                    Width="220"
                    IsSnapToTickEnabled="False"
                    Maximum="180"
                    Minimum="-180"
                    TickFrequency="15"
                    ValueChanged="RotationSlider_ValueChanged"
                    Value="0" />
                <TextBlock
                    x:Name="RotationValueText"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Text="0°" />
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Margin="4"
                    Click="CropButton_Click"
                    Content="Recortar"
                    Cursor="Hand" />
                <Button
                    Width="100"
                    Margin="4"
                    Click="OkButton_Click"
                    Content="Aceptar"
                    Cursor="Hand" />
                <Button
                    Width="100"
                    Margin="4"
                    Background="Black"
                    Click="CancelButton_Click"
                    Content="Cancelar"
                    Cursor="Hand"
                    Foreground="White" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
