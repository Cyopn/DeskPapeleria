<Window
	x:Class="DeskApp.SpecialServiceDetailsWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="clr-namespace:DeskApp"
	Title="Detalle Servicio Especial"
	Width="520"
	Height="420"
	WindowStartupLocation="CenterOwner">
	<Window.Resources>
		<Style TargetType="Button">
			<Setter Property="Padding" Value="8,4" />
			<Setter Property="FontSize" Value="18" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border
							x:Name="ButtonBorder"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="8">
							<ContentPresenter
								Margin="{TemplateBinding Padding}"
								HorizontalAlignment="Center"
								VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsEnabled" Value="False">
								<Setter TargetName="ButtonBorder" Property="Background" Value="#FFE5E5E5" />
								<Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFBDBDBD" />
								<Setter Property="Foreground" Value="#FF8C8C8C" />
								<Setter Property="Opacity" Value="0.75" />
								<Setter Property="Cursor" Value="Arrow" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>
	<Grid Margin="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<TextBlock
			x:Name="TitleText"
			FontSize="22"
			FontWeight="Bold" />

		<StackPanel Grid.Row="1" Margin="0,10,0,10">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<Grid Grid.Column="0">
					<Grid.RowDefinitions>
						<RowDefinition Height="*" />
						<RowDefinition Height="*" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<StackPanel
						Grid.Row="0"
						Margin="0,6"
						Orientation="Vertical">
						<TextBlock
							FontSize="18"
							FontWeight="SemiBold"
							Text="Tipo:" />
						<TextBlock x:Name="TypeText" FontSize="16" />
					</StackPanel>

					<StackPanel
						Grid.Row="1"
						Margin="0,6"
						Orientation="Vertical">
						<TextBlock
							FontSize="18"
							FontWeight="SemiBold"
							Text="Estado:" />
						<TextBlock x:Name="StatusText" FontSize="16" />
					</StackPanel>

					<StackPanel
						Grid.Row="2"
						Margin="0,6"
						Orientation="Vertical">
						<TextBlock
							FontSize="18"
							FontWeight="SemiBold"
							Text="Modo:" />
						<TextBlock x:Name="ModeText" FontSize="16" />
					</StackPanel>

				</Grid>
				<Grid Grid.Column="1">
					<Grid.RowDefinitions>
						<RowDefinition Height="*" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<StackPanel
						Grid.Row="0"
						Margin="0,6"
						Orientation="Vertical">
						<TextBlock
							FontSize="18"
							FontWeight="SemiBold"
							Text="Entrega:" />
						<TextBlock x:Name="DeliveryText" FontSize="16" />
					</StackPanel>

					<StackPanel
						Grid.Row="1"
						Margin="0,6"
						Orientation="Vertical">
						<TextBlock
							FontSize="18"
							FontWeight="SemiBold"
							Text="Observaciones:" />
						<TextBlock
							x:Name="ObservationsText"
							FontSize="16"
							TextWrapping="Wrap" />
					</StackPanel>
				</Grid>
			</Grid>

			<Separator Margin="0,8" />

			<!--  Bound details  -->
			<StackPanel
				x:Name="BoundPanel"
				Margin="0,6"
				Visibility="Collapsed">
				<TextBlock
					FontSize="18"
					FontWeight="Bold"
					Text="Encuadernado" />
				<TextBlock FontSize="16"><Run FontWeight="SemiBold" Text="Tipo de tapa: " /> <Run x:Name="BoundCoverType" /></TextBlock>
				<TextBlock FontSize="16"><Run FontWeight="SemiBold" Text="Color de tapa: " /> <Run x:Name="BoundCoverColor" /></TextBlock>
				<TextBlock FontSize="16"><Run FontWeight="SemiBold" Text="Espiral: " /> <Run x:Name="BoundSpiral" /></TextBlock>
			</StackPanel>

			<!--  Spiral details  -->
			<StackPanel
				x:Name="SpiralPanel"
				Margin="0,6"
				Visibility="Collapsed">
				<TextBlock
					FontSize="18"
					FontWeight="Bold"
					Text="Anillado" />
				<TextBlock FontSize="16"><Run FontWeight="SemiBold" Text="Tipo de anillado: " /> <Run x:Name="SpiralType" /></TextBlock>
			</StackPanel>

			<!--  Document details  -->
			<StackPanel
				x:Name="DocumentPanel"
				Margin="0,6"
				Visibility="Collapsed">
				<TextBlock
					FontSize="18"
					FontWeight="Bold"
					Text="Documento especial" />
				<TextBlock FontSize="16"><Run FontWeight="SemiBold" Text="Tipo de documento: " /> <Run x:Name="DocumentType" /></TextBlock>
			</StackPanel>

			<!--  Photo details  -->
			<StackPanel
				x:Name="PhotoPanel"
				Margin="0,6"
				Visibility="Collapsed">
				<TextBlock
					FontSize="18"
					FontWeight="Bold"
					Text="Fotografía" />
				<TextBlock FontSize="16"><Run FontWeight="SemiBold" Text="Tamaño: " /> <Run x:Name="PhotoSize" /></TextBlock>
				<TextBlock FontSize="16"><Run FontWeight="SemiBold" Text="Tipo papel: " /> <Run x:Name="PhotoPaperType" /></TextBlock>
			</StackPanel>
		</StackPanel>

		<StackPanel
			Grid.Row="2"
			HorizontalAlignment="Right"
			Orientation="Horizontal">
			<Button
				Width="100"
				Margin="6"
				Click="Close_Click"
                Cursor="Hand">
				Cerrar
			</Button>
		</StackPanel>
	</Grid>
</Window>
