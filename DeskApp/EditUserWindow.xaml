<Window x:Class="DeskApp.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Editar Empleado"
        Height="480" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" 
                    Value="#D9D9D9"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Padding" 
                    Value="2,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" 
                    Value="#D9D9D9"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Padding" 
                    Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  Content="{Binding SelectedItem.Display, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Stretch"/>
                                <ToggleButton x:Name="ToggleButton"
                                              Grid.Column="1"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              HorizontalContentAlignment="Center"
                                              VerticalContentAlignment="Center"
                                              Cursor="Hand"
                                              OverridesDefaultStyle="True">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" BorderThickness="0">
                                                <Path Data="M 0 0 L 6 6 L 12 0 Z"
                                                      Fill="#555"
                                                      Stretch="Uniform"
                                                      Width="12"
                                                      Height="6"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Border Background="#D9D9D9"
                                        CornerRadius="8 8 8 8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                    <ScrollViewer Margin="0"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" 
                                            Background="{TemplateBinding Background}" 
                                            CornerRadius="8 8 8 8" 
                                            Padding="8,4">
                                        <ContentPresenter Margin="0"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" 
                                                 Value="True">
                                            <Setter TargetName="Bd" 
                                                    Property="Background" 
                                                    Value="#E0E0E0"/>
                                            <Setter Property="Cursor" 
                                                    Value="Hand"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" 
                                                 Value="True">
                                            <Setter TargetName="Bd" 
                                                    Property="Background" 
                                                    Value="#C0C0C0"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" 
                                                 Value="False">
                                            <Setter TargetName="Bd" 
                                                    Property="Opacity" 
                                                    Value="0.6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" 
                    Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Editar empleado" 
                   FontSize="24" 
                   FontWeight="Bold"/>
        <StackPanel Grid.Row="1" Margin="0,5">
            <TextBlock Text="Nombres" 
                       FontWeight="Bold" 
                       FontSize="18"/>
            <TextBox x:Name="NamesTextBox" 
                     FontSize="16"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,5">
            <TextBlock Text="Usuario" 
                       FontWeight="Bold"
                       FontSize="18"/>
            <TextBox x:Name="UsernameTextBox"
                     FontSize="16"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Margin="0,5">
            <TextBlock Text="Apellidos" 
                       FontWeight="Bold"
                       FontSize="18"/>
            <TextBox x:Name="LastnamesTextBox"
                     FontSize="16"/>
        </StackPanel>
        <StackPanel Grid.Row="4" Margin="0,5">
            <TextBlock Text="Email" 
                       FontWeight="Bold"
                       FontSize="18"/>
            <TextBox x:Name="EmailTextBox"
                     FontSize="16"/>
        </StackPanel>
        <Grid Grid.Row="5" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,5,5,0">
                <TextBlock Text="Rol" 
                           FontWeight="Bold"
                           FontSize="18"/>
                <ComboBox x:Name="RoleComboBox"
                          SelectedIndex="0"
                          FontSize="16"
                          DisplayMemberPath="Display"
                          SelectedValuePath="Value"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="5,5,0,0">
                <TextBlock Text="Telefono" 
                           FontWeight="Bold"
                           FontSize="18"/>
                <TextBox x:Name="PhoneTextBox"
                         FontSize="16"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,0,0">
            <Button Content="Eliminar"
                    Width="100"
                    Margin="0,0,15,0"
                    Click="DeleteButton_Click"
                    Background="#FF4D4D"
                    Foreground="White"
                    FontSize="18"
                    Cursor="Hand"/>
            <Button Content="Guardar" 
                    Width="100" 
                    Margin="0,0,15,0" 
                    Click="SaveButton_Click"
                    Background="Transparent"
                    FontSize="18"
                    Cursor="Hand"/>
            <Button Content="Cancelar" 
                    Width="100" 
                    Click="CancelButton_Click"
                    Background="Black"
                    Foreground="White"
                    FontSize="18"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
