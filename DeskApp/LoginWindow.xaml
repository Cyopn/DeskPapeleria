<Window
    x:Class="DeskApp.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DeskApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Iniciar sesión"
    Width="1050"
    Height="700"
    MinWidth="1050"
    MinHeight="700"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect
                                    x:Name="shadow"
                                    BlurRadius="5"
                                    Opacity="0.3"
                                    ShadowDepth="3" />
                            </Border.Effect>
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextBlock.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="shadow"
                                                Storyboard.TargetProperty="ShadowDepth"
                                                To="8"
                                                Duration="0:0:0.2" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="shadow"
                                                Storyboard.TargetProperty="BlurRadius"
                                                To="15"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="shadow"
                                                Storyboard.TargetProperty="ShadowDepth"
                                                To="3"
                                                Duration="0:0:0.2" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="shadow"
                                                Storyboard.TargetProperty="BlurRadius"
                                                To="5"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="shadow"
                                                Storyboard.TargetProperty="ShadowDepth"
                                                To="1"
                                                Duration="0:0:0.1" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="shadow"
                                                Storyboard.TargetProperty="BlurRadius"
                                                To="3"
                                                Duration="0:0:0.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AnimatedTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        x:Name="textShadow"
                        BlurRadius="3"
                        Opacity="0.3"
                        ShadowDepth="2"
                        Color="Black" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.ShadowDepth)"
                                    To="5"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.BlurRadius)"
                                    To="8"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.Opacity)"
                                    To="0.5"
                                    Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.ShadowDepth)"
                                    To="2"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.BlurRadius)"
                                    To="3"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.Opacity)"
                                    To="0.3"
                                    Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Image
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Stretch="UniformToFill">
                    <Image.Source>
                        <BitmapImage UriSource="pack://application:,,,/Resources/bg-login.png" />
                    </Image.Source>
                </Image>
            </Grid>
            <Grid Grid.Column="1" />
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" />
            <Border
                Grid.Column="1"
                Background="White"
                CornerRadius="60,0,0,60">
                <Grid Margin="50">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="1"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FontFamily="Dubai Medium"
                        FontSize="40"
                        FontWeight="Bold"
                        Text="Bienvenido" />
                    <Image
                        Grid.Row="2"
                        MinWidth="50"
                        MaxWidth="190"
                        Margin="120,20,120,20"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">
                        <Image.Source>
                            <BitmapImage UriSource="pack://application:,,,/Resources/user.png" />
                        </Image.Source>
                    </Image>
                    <Border
                        Grid.Row="3"
                        Height="40"
                        Margin="50,10,50,10"
                        Padding="3"
                        Background="#D9D9D9"
                        CornerRadius="10">
                        <Grid>
                            <TextBox
                                x:Name="UsernameTextBox"
                                Padding="35,0,5,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="20" />
                            <TextBlock
                                Padding="35,0,5,0"
                                VerticalAlignment="Center"
                                FontSize="22"
                                Foreground="#808080"
                                IsHitTestVisible="False"
                                Text="Nombre de usuario">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=UsernameTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Image
                                Width="20"
                                Height="20"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Left"
                                IsHitTestVisible="False">
                                <Image.Source>
                                    <BitmapImage UriSource="pack://application:,,,/Resources/user.png" />
                                </Image.Source>
                            </Image>
                        </Grid>
                    </Border>
                    <Border
                        Grid.Row="4"
                        Height="40"
                        Margin="50,10,50,10"
                        Padding="3"
                        Background="#D9D9D9"
                        CornerRadius="10">
                        <Grid>
                            <PasswordBox
                                x:Name="PasswordBox"
                                Padding="35,0,40,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="20"
                                PasswordChanged="PasswordBox_PasswordChanged" />
                            <TextBox
                                x:Name="PasswordTextBox"
                                Padding="35,0,40,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="20"
                                TextChanged="PasswordTextBox_TextChanged"
                                Visibility="Collapsed" />
                            <TextBlock
                                x:Name="PasswordHint"
                                Padding="35,0,40,0"
                                VerticalAlignment="Center"
                                FontSize="22"
                                Foreground="#808080"
                                IsHitTestVisible="False"
                                Text="Contraseña"
                                Visibility="Visible" />
                            <Image
                                Width="20"
                                Height="20"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Left"
                                IsHitTestVisible="False">
                                <Image.Source>
                                    <BitmapImage UriSource="pack://application:,,,/Resources/lock.png" />
                                </Image.Source>
                            </Image>
                            <Button
                                x:Name="TogglePasswordButton"
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="TogglePasswordButton_Click"
                                Cursor="Hand">
                                <TextBlock
                                    x:Name="TogglePasswordIcon"
                                    FontSize="18"
                                    Foreground="#808080"
                                    Text="👁" />
                            </Button>
                        </Grid>
                    </Border>
                    <Button
                        Grid.Row="5"
                        Height="50"
                        Margin="100,20,100,10"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        BorderThickness="0"
                        Click="LoginButton_Click"
                        Content="Iniciar sesión"
                        Cursor="Hand"
                        FontFamily="Dubai Medium"
                        FontSize="28"
                        FontWeight="Bold"
                        Style="{StaticResource RoundedButtonStyle}">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#FFDF1E" />
                                <GradientStop Offset="1" Color="#FDC045" />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <TextBlock
                        Grid.Row="6"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        FontSize="22"
                        MouseLeftButtonDown="RegisterTextBlock_Click"
                        Style="{StaticResource AnimatedTextBlockStyle}"
                        Text="Registrate" />
                </Grid>
            </Border>
        </Grid>
        <Grid
            x:Name="NotificationContainer"
            Margin="20"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            IsHitTestVisible="False" />
    </Grid>
</Window>
