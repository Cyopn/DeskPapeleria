<Window x:Class="DeskApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeskApp"
        mc:Ignorable="d"
        Title="Iniciar sesión"
        Height="700" 
        Width="1050"
        MinHeight="700" 
        MinWidth="1050"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect x:Name="shadow" 
                                          ShadowDepth="3" 
                                          BlurRadius="5" 
                                          Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"
                                      TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="shadow"
                                                     Storyboard.TargetProperty="ShadowDepth"
                                                     To="8"
                                                     Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="15"
                                                     Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="shadow"
                                                     Storyboard.TargetProperty="ShadowDepth"
                                                     To="3"
                                                     Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="5"
                                                     Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger 
                        Property="IsPressed" 
                        Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="shadow"
                                                     Storyboard.TargetProperty="ShadowDepth"
                                                     To="1"
                                                     Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="3"
                                                     Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnimatedTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect x:Name="textShadow"
                                      ShadowDepth="2"
                                      BlurRadius="3"
                                      Opacity="0.3"
                                      Color="Black"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.ShadowDepth)"
                                                 To="5"
                                                 Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.BlurRadius)"
                                                 To="8"
                                                 Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.Opacity)"
                                                 To="0.5"
                                                 Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.ShadowDepth)"
                                                 To="2"
                                                 Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.BlurRadius)"
                                                 To="3"
                                                 Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.Opacity)"
                                                 To="0.3"
                                                 Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Image Stretch="UniformToFill" 
                       VerticalAlignment="Stretch" 
                       HorizontalAlignment="Stretch">
                    <Image.Source>
                        <BitmapImage 
                            UriSource="pack://application:,,,/Resources/bg-login.png"/>
                    </Image.Source>
                </Image>
            </Grid>
            <Grid Grid.Column="1">
            </Grid>
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
            </Grid>
            <Border Grid.Column="1" 
                    Background="White"
                    CornerRadius="60,0,0,60">
                <Grid Margin="50">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="1"
                               Text="Bienvenido" 
                               FontSize="40" 
                               FontFamily="Dubai Medium"
                               FontWeight="Bold" 
                               Margin="10" 
                               HorizontalAlignment="Center"/>
                    
                    <Image Grid.Row="2"
                           Margin="120,20,120,20"
                           MinWidth="50"
                           MaxWidth="190"
                           HorizontalAlignment="Stretch" 
                           VerticalAlignment="Center">
                        <Image.Source>
                            <BitmapImage UriSource="pack://application:,,,/Resources/user.png"/>
                        </Image.Source>
                    </Image>

                    <Border Grid.Row="3"
                            Margin="50,10,50,10" 
                            Height="40"
                            CornerRadius="10"
                            Background="#D9D9D9"
                            Padding="3">
                        <Grid>
                            <TextBox x:Name="UsernameTextBox" 
                                     Padding="35,0,5,0"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="20"/>
                            <TextBlock Text="Nombre de usuario"
                                       Padding="35,0,5,0"
                                       VerticalAlignment="Center"
                                       FontSize="22"
                                       Foreground="#808080"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=UsernameTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Image Width="20" 
                                   Height="20" 
                                   HorizontalAlignment="Left" 
                                   Margin="8,0,0,0"
                                   IsHitTestVisible="False">
                                <Image.Source>
                                    <BitmapImage UriSource="pack://application:,,,/Resources/user.png"/>
                                </Image.Source>
                            </Image>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4"
                            Margin="50,10,50,10" 
                            Height="40"
                            CornerRadius="10"
                            Background="#D9D9D9"
                            Padding="3">
                        <Grid>
                            <PasswordBox x:Name="PasswordBox" 
                                         Padding="35,0,40,0"
                                         VerticalContentAlignment="Center"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="20"
                                         PasswordChanged="PasswordBox_PasswordChanged"/>
                            <TextBox x:Name="PasswordTextBox"
                                     Padding="35,0,40,0"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="20"
                                     Visibility="Collapsed"
                                     TextChanged="PasswordTextBox_TextChanged"/>
                            <TextBlock x:Name="PasswordHint"
                                       Text="Contraseña"
                                       Padding="35,0,40,0"
                                       VerticalAlignment="Center"
                                       FontSize="22"
                                       Foreground="#808080"
                                       IsHitTestVisible="False"
                                       Visibility="Visible"/>
                            <Image Width="20" 
                                   Height="20" 
                                   HorizontalAlignment="Left" 
                                   Margin="8,0,0,0"
                                   IsHitTestVisible="False">
                                <Image.Source>
                                    <BitmapImage UriSource="pack://application:,,,/Resources/lock.png"/>
                                </Image.Source>
                            </Image>
                            <Button x:Name="TogglePasswordButton"
                                    Width="30"
                                    Height="30"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,5,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="TogglePasswordButton_Click">
                                <TextBlock x:Name="TogglePasswordIcon"
                                           Text="👁"
                                           FontSize="18"
                                           Foreground="#808080"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Button Grid.Row="5"
                            Content="Iniciar sesión"
                            Margin="100,20,100,10"
                            Height="50"
                            HorizontalAlignment="Stretch" 
                            VerticalAlignment="Center" 
                            FontSize="28" 
                            FontFamily="Dubai Medium"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Style="{StaticResource RoundedButtonStyle}"
                            Cursor="Hand"
                            Click="LoginButton_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFDF1E" Offset="0"/>
                                <GradientStop Color="#FDC045" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>

                    <TextBlock Grid.Row="6"
                               Text="Registrate"
                               HorizontalAlignment="Center" 
                               Margin="0,10,0,0"
                               FontSize="22"
                               Style="{StaticResource AnimatedTextBlockStyle}"
                               Cursor="Hand"
                               MouseLeftButtonDown="RegisterTextBlock_Click"/>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="NotificationContainer" 
              IsHitTestVisible="False"
              VerticalAlignment="Top"
              HorizontalAlignment="Right"
              Margin="20"/>
    </Grid>
</Window>
