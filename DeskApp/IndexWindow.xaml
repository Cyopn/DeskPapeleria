<Window
    x:Class="DeskApp.IndexWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DeskApp"
    xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="IndexWindow"
    Width="1500"
    Height="900"
    MinWidth="1500"
    MinHeight="900"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="15,10" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="25">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="ActiveMenuButtonStyle"
            BasedOn="{StaticResource MenuButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OtrosContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#D9D9D9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OtrosMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border
                            x:Name="ItemBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12">
                            <ContentPresenter
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <local:RoleDisplayConverter x:Key="RoleDisplayConverter" />
        <local:RoleToBrushConverter x:Key="RoleToBrushConverter" />
        <local:BoolSiNoConverter x:Key="BoolSiNoConverter" />
        <local:StatusDisplayConverter x:Key="StatusDisplayConverter" />
        <local:ConnectionTypeDisplayConverter x:Key="ConnectionTypeDisplayConverter" />
        <local:PaymentMethodDisplayConverter x:Key="PaymentMethodDisplayConverter" />
        <Style x:Key="DataGridCellTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid>
                    <Image
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Stretch="UniformToFill">
                        <Image.Source>
                            <BitmapImage UriSource="pack://application:,,,/Resources/bg-employee.png" />
                        </Image.Source>
                    </Image>
                    <Rectangle Fill="Black" Opacity="0.6" />
                </Grid>
            </Grid>
            <Grid Grid.Row="1" Background="White" />
        </Grid>
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                Margin="0,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="36"
                FontWeight="Bold"
                Foreground="White"
                Text="Centro de Administración" />
            <Border
                Grid.Row="1"
                Margin="10,10,10,20"
                HorizontalAlignment="Center"
                Background="#D9D9D9"
                CornerRadius="40">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        Margin="10"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            x:Name="EmpleadosButton"
                            Padding="5,10,15,10"
                            Click="MenuButton_Click"
                            Style="{StaticResource MenuButtonStyle}"
                            Tag="Empleados">
                            <Grid>
                                <Image
                                    Width="20"
                                    Height="20"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False">
                                    <Image.Source>
                                        <BitmapImage UriSource="pack://application:,,,/Resources/employee.png" />
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Padding="35,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="17"
                                    Foreground="Black"
                                    Text="Empleados" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="ProductosButton"
                            Padding="5,10,15,10"
                            Click="MenuButton_Click"
                            Style="{StaticResource MenuButtonStyle}"
                            Tag="Productos">
                            <Grid>
                                <Image
                                    Width="20"
                                    Height="20"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False">
                                    <Image.Source>
                                        <BitmapImage UriSource="pack://application:,,,/Resources/boxes.png" />
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Padding="35,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="17"
                                    Foreground="Black"
                                    Text="Productos" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="ImpresorasButton"
                            Padding="5,10,15,10"
                            Click="MenuButton_Click"
                            Style="{StaticResource MenuButtonStyle}"
                            Tag="Impresoras">
                            <Grid>
                                <Image
                                    Width="20"
                                    Height="20"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False">
                                    <Image.Source>
                                        <BitmapImage UriSource="pack://application:,,,/Resources/printer.png" />
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Padding="35,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="17"
                                    Foreground="Black"
                                    Text="Impresoras" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="TrasaccionesButton"
                            Padding="5,10,15,10"
                            Click="MenuButton_Click"
                            Style="{StaticResource MenuButtonStyle}"
                            Tag="Transacciones">
                            <Grid>
                                <Image
                                    Width="20"
                                    Height="20"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False">
                                    <Image.Source>
                                        <BitmapImage UriSource="pack://application:,,,/Resources/sales.png" />
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Padding="35,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="17"
                                    Foreground="Black"
                                    Text="Transacciones" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="UsuariosButton"
                            Padding="5,10,15,10"
                            Click="MenuButton_Click"
                            Style="{StaticResource MenuButtonStyle}"
                            Tag="Usuarios">
                            <Grid>
                                <Image
                                    Width="20"
                                    Height="20"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False">
                                    <Image.Source>
                                        <BitmapImage UriSource="pack://application:,,,/Resources/user.png" />
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Padding="35,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="17"
                                    Foreground="Black"
                                    Text="Usuarios" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="OtrosButton"
                            Padding="5,10,15,10"
                            Click="OtrosButton_Click"
                            Style="{StaticResource MenuButtonStyle}"
                            Tag="Otros">
                            <Button.ContextMenu>
                                <ContextMenu
                                    Placement="Bottom"
                                    StaysOpen="False"
                                    Style="{StaticResource OtrosContextMenuStyle}">
                                    <MenuItem
                                        Click="DashboardButton_Click"
                                        Header="Ver Dashboard"
                                        Style="{StaticResource OtrosMenuItemStyle}" />
                                    <MenuItem
                                        Click="LogoutButton_Click"
                                        Header="Cerrar sesión"
                                        Style="{StaticResource OtrosMenuItemStyle}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Grid>
                                <Image
                                    Width="20"
                                    Height="20"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False">
                                    <Image.Source>
                                        <BitmapImage UriSource="pack://application:,,,/Resources/hand.png" />
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Padding="35,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="17"
                                    Foreground="Black"
                                    Text="Otros" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <Border
                Grid.Row="3"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1,0,1,1"
                CornerRadius="20,20,20,20">
                <Grid>
                    <Grid x:Name="Tab1Content" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,10,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Margin="20,0"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="#333333"
                                Text="Lista de Empleados" />
                            <Border
                                Grid.Column="1"
                                Height="40"
                                Margin="50,0,10,0"
                                Padding="3"
                                HorizontalAlignment="Stretch"
                                Background="#D9D9D9"
                                CornerRadius="10">
                                <Grid>
                                    <TextBox
                                        x:Name="EmployeesSearchTextBox"
                                        Padding="5,0,35,0"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="16"
                                        TextChanged="EmployeesSearchTextBox_TextChanged" />
                                    <TextBlock
                                        Padding="5,0,35,0"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Foreground="#808080"
                                        IsHitTestVisible="False"
                                        Text="Buscar">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=EmployeesSearchTextBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Foreground="#808080"
                                        IsHitTestVisible="False"
                                        Text="🔍" />
                                </Grid>
                            </Border>
                            <Button
                                Grid.Column="2"
                                Width="40"
                                Height="40"
                                Margin="0,0,10,0"
                                Background="#D9D9D9"
                                BorderThickness="0"
                                Click="ReloadUsersButton_Click"
                                Content="↻"
                                Cursor="Hand"
                                FontSize="18"
                                ToolTip="Recargar empleados" />
                        </Grid>
                        <TextBlock
                            Grid.Row="1"
                            Margin="20,0,0,0"
                            FontSize="20"
                            Foreground="#333333"
                            Text="Personal registrado en el sistema" />

                        <Border
                            Grid.Row="2"
                            Margin="20,10"
                            Padding="10"
                            Background="#F9F9F9"
                            CornerRadius="5">
                            <DataGrid
                                x:Name="EmployeesDataGrid"
                                Margin="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                AlternatingRowBackground="#FFF7F7F7"
                                AutoGenerateColumns="False"
                                BorderThickness="0"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="False"
                                FontSize="20"
                                FontWeight="DemiBold"
                                GridLinesVisibility="None"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                ItemsSource="{Binding Users}"
                                RowBackground="White"
                                SelectionChanged="EmployeesDataGrid_SelectionChanged">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="BorderBrush" Value="Black" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="OverridesDefaultStyle" Value="False" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="Black" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderThickness" Value="0" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="BorderBrush" Value="Black" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        <Setter Property="Margin" Value="5,5,5,5" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding IdUser}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        FontSize="18"
                                        Header="N. empleado" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Username}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        FontSize="18"
                                        Header="Usuario" />
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding Names}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        FontSize="18"
                                        Header="Nombre" />
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding Lastnames}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        FontSize="18"
                                        Header="Apellido" />
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding Email}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        FontSize="18"
                                        Header="Email" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Phone}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        FontSize="18"
                                        Header="Teléfono" />
                                    <DataGridTemplateColumn Width="*" Header="Rol">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Padding="6,4"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding Role, Converter={StaticResource RoleToBrushConverter}}"
                                                    CornerRadius="8"
                                                    SnapsToDevicePixels="True">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="18"
                                                        FontWeight="DemiBold"
                                                        Foreground="#111111"
                                                        Text="{Binding Role, Converter={StaticResource RoleDisplayConverter}}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="Auto" Header="Editar">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Margin="5,8"
                                                    Padding="15,5"
                                                    HorizontalAlignment="Center"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Click="EditUser_Click"
                                                    Cursor="Hand"
                                                    Tag="{Binding}">
                                                    <Image
                                                        Width="20"
                                                        Height="20"
                                                        Source="pack://application:,,,/Resources/pencil.png"
                                                        Stretch="Uniform" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <Grid x:Name="Tab2Content" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Margin="20,0"
                            HorizontalAlignment="Center"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="#333333"
                            Text="Administrador de Productos" />
                        <TextBlock
                            Grid.Row="1"
                            Margin="10,0"
                            HorizontalAlignment="Center"
                            FontSize="18"
                            Foreground="#333333"
                            Text="Gestiona el inventario productos" />
                        <Grid Grid.Row="2" Margin="10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Grid.Column="1"
                                Margin="250,0,50,0"
                                HorizontalAlignment="Stretch"
                                Background="#D9D9D9"
                                Click="AddProductButton_Click"
                                Cursor="Hand"
                                FontSize="18"
                                Foreground="Black">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Image
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,8,0"
                                        IsHitTestVisible="False"
                                        Source="pack://application:,,,/Resources/mas.png" />
                                    <TextBlock VerticalAlignment="Center" Text="Agregar Producto" />
                                </StackPanel>
                            </Button>
                            <Border
                                Grid.Column="0"
                                Height="40"
                                Margin="50,0"
                                Padding="3"
                                HorizontalAlignment="Stretch"
                                Background="#D9D9D9"
                                CornerRadius="10">
                                <Grid>
                                    <TextBox
                                        x:Name="ProductsSearchTextBox"
                                        Padding="5,0,35,0"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="16"
                                        TextChanged="ProductsSearchTextBox_TextChanged" />
                                    <TextBlock
                                        Padding="5,0,35,0"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Foreground="#808080"
                                        IsHitTestVisible="False"
                                        Text="Buscar">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=ProductsSearchTextBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Foreground="#808080"
                                        IsHitTestVisible="False"
                                        Text="🔍" />
                                </Grid>
                            </Border>
                            <Button
                                Grid.Column="2"
                                Width="40"
                                Height="40"
                                Margin="0,0,10,0"
                                Background="#D9D9D9"
                                BorderThickness="0"
                                Click="ReloadProductsButton_Click"
                                Content="↻"
                                Cursor="Hand"
                                FontSize="18"
                                ToolTip="Recargar productos" />
                        </Grid>

                        <Border
                            Grid.Row="3"
                            Margin="20,10"
                            Padding="10"
                            Background="#F9F9F9"
                            CornerRadius="5">
                            <DataGrid
                                x:Name="ProductsDataGrid"
                                Margin="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                AlternatingRowBackground="#FFF7F7F7"
                                AutoGenerateColumns="False"
                                BorderThickness="0"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="False"
                                FontSize="20"
                                FontWeight="DemiBold"
                                GridLinesVisibility="None"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                ItemsSource="{Binding Products}"
                                RowBackground="White">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="BorderBrush" Value="Black" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="OverridesDefaultStyle" Value="False" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="Black" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
