                                        FontSize="16"
                                        TextChanged="OtherUsersSearchTextBox_TextChanged" />
                                    <TextBlock
                                        Padding="5,0,35,0"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Foreground="#808080"
                                        IsHitTestVisible="False"
                                        Text="Buscar">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=OtherUsersSearchTextBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Foreground="#808080"
                                        IsHitTestVisible="False"
                                        Text="🔍" />
                                </Grid>
                            </Border>
                            <Button
                                Grid.Column="2"
                                Width="40"
                                Height="40"
                                Margin="0,0,10,0"
                                Background="#D9D9D9"
                                BorderThickness="0"
                                Click="ReloadOtherUsersButton_Click"
                                Content="↻"
                                Cursor="Hand"
                                FontSize="18"
                                ToolTip="Recargar usuarios" />
                        </Grid>
                        <TextBlock
                            Grid.Row="1"
                            Margin="20,0,0,0"
                            FontSize="20"
                            Foreground="#333333"
                            Text="Usuarios con otros roles" />

                        <Border
                            Grid.Row="2"
                            Margin="20,10"
                            Padding="10"
                            Background="#F9F9F9"
                            CornerRadius="5">
                            <DataGrid
                                x:Name="OtherUsersDataGrid"
                                Margin="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                AlternatingRowBackground="#FFF7F7F7"
                                AutoGenerateColumns="False"
                                BorderThickness="0"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="False"
                                FontSize="20"
                                FontWeight="DemiBold"
                                GridLinesVisibility="None"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                ItemsSource="{Binding OtherUsers}"
                                RowBackground="White">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="BorderBrush" Value="Black" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="OverridesDefaultStyle" Value="False" />
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderThickness" Value="0" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="BorderBrush" Value="Black" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        <Setter Property="Margin" Value="5,5,5,5" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding IdUser}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Header="N. usuario" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Username}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Header="Usuario" />
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding Names}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Header="Nombre" />
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding Lastnames}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Header="Apellido" />
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding Email}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Header="Email" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Phone}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Header="Teléfono" />
                                    <DataGridTemplateColumn Width="*" Header="Rol">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Padding="6,4"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding Role, Converter={StaticResource RoleToBrushConverter}}"
                                                    CornerRadius="8">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="18"
                                                        FontWeight="DemiBold"
                                                        Foreground="#111111"
                                                        Text="{Binding Role, Converter={StaticResource RoleDisplayConverter}}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="Auto" Header="Editar">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Margin="5,8"
                                                    Padding="15,5"
                                                    HorizontalAlignment="Center"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Click="EditUser_Click"
                                                    CommandParameter="other-users"
                                                    Cursor="Hand"
                                                    Tag="{Binding}">
                                                    <Image
                                                        Width="20"
                                                        Height="20"
                                                        Source="pack://application:,,,/Resources/pencil.png"
                                                        Stretch="Uniform" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <Grid x:Name="Tab6Content" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Margin="20,0"
                            HorizontalAlignment="Center"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="#333333"
                            Text="Dashboard de Transacciones" />
                        <Border
                            Grid.Row="1"
                            Margin="40"
                            Padding="20"
                            Background="#F9F9F9"
                            CornerRadius="10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock
                                        x:Name="DashboardTotalTransactions"
                                        Margin="0,0,0,5"
                                        FontSize="20"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        x:Name="DashboardTotalAmount"
                                        Margin="0,0,0,5"
                                        FontSize="20"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        x:Name="DashboardCompletedCount"
                                        Margin="0,0,0,5"
                                        FontSize="18" />
                                    <TextBlock
                                        x:Name="DashboardPendingCount"
                                        Margin="0,0,0,5"
                                        FontSize="18" />

                                    <StackPanel
                                        Margin="0,0,0,20"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                        <Button
                                            Margin="0,0,10,0"
                                            Padding="10,0"
                                            Background="#1E88E5"
                                            BorderThickness="0"
                                            Click="ExportMetricsToExcel_Click"
                                            Content="Exportar métricas a Excel"
                                            Cursor="Hand"
                                            FontSize="16"
                                            Foreground="White" />
                                        <Button
                                            Margin="0,0,10,0"
                                            Padding="10,0"
                                            Background="#D9D9D9"
                                            BorderThickness="0"
                                            Click="ReloadDashboardButton_Click"
                                            Content="Recargar gráficas"
                                            Cursor="Hand"
                                            FontSize="16"
                                            Foreground="Black" />
                                        <StackPanel
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal">
                                            <Border
                                                Margin="0,0,10,0"
                                                Padding="6,6"
                                                Background="#D9D9D9"
                                                CornerRadius="8">
                                                <ComboBox
                                                    x:Name="DashboardPeriodFilterComboBox"
                                                    MinWidth="170"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    SelectionChanged="DashboardPeriodFilter_SelectionChanged">
                                                    <ComboBoxItem
                                                        Content="Todo el historial"
                                                        IsSelected="True"
                                                        Tag="all" />
                                                    <ComboBoxItem Content="Hoy" Tag="today" />
                                                    <ComboBoxItem Content="Esta semana" Tag="week" />
                                                    <ComboBoxItem Content="Este mes" Tag="month" />
                                                    <ComboBoxItem Content="Rango personalizado" Tag="range" />
                                                </ComboBox>
                                            </Border>
                                            <DatePicker
                                                x:Name="DashboardFromDatePicker"
                                                Width="130"
                                                Margin="0,0,8,0"
                                                SelectedDateChanged="DashboardPeriodDatePicker_SelectedDateChanged"
                                                Visibility="Collapsed" />
                                            <DatePicker
                                                x:Name="DashboardToDatePicker"
                                                Width="130"
                                                Margin="0,0,10,0"
                                                SelectedDateChanged="DashboardPeriodDatePicker_SelectedDateChanged"
                                                Visibility="Collapsed" />
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock
                                        Margin="0,0,0,5"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Text="Ingresos totales en el tiempo" />
                                    <lvc:CartesianChart
                                        x:Name="SalesOverTimeLineChart"
                                        Height="200"
                                        Margin="0,0,0,10" />
                                    <TextBlock
                                        Margin="0,6,0,6"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Text="Ingresos acumulados" />
                                    <lvc:CartesianChart
                                        x:Name="AccumulatedSalesLineChart"
                                        Height="120"
                                        Margin="0,0,0,20" />

                                    <UniformGrid Margin="0,0,0,20" Columns="2">
                                        <StackPanel Margin="10">
                                            <TextBlock
                                                x:Name="TicketAverageValue"
                                                FontSize="18"
                                                FontWeight="Bold" />
                                            <lvc:CartesianChart
                                                x:Name="AverageTicketLineChart"
                                                Height="200"
                                                Margin="0,0,0,0" />
                                        </StackPanel>
                                        <StackPanel Margin="10">
                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="Ingresos por hora del día" />
                                            <lvc:CartesianChart
                                                x:Name="SalesByHourLineChart"
                                                Height="200"
                                                Margin="0,0,0,0" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <UniformGrid Margin="0,0,0,20" Columns="2">
                                        <StackPanel Margin="10">
                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="Distribución de métodos de pago" />
                                            <lvc:PieChart
                                                x:Name="SalesByPaymentMethodPieChart"
                                                Height="220"
                                                Margin="0,10,0,0"
                                                HoverPushOut="8"
                                                InnerRadius="60"
                                                LegendLocation="Right" />
                                        </StackPanel>
                                        <StackPanel Margin="10">
                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="Ingresos por categoría" />
                                            <lvc:PieChart
                                                x:Name="SalesByCategoryPieChart"
                                                Height="220"
                                                Margin="0,10,0,0"
                                                HoverPushOut="8"
                                                InnerRadius="60"
                                                LegendLocation="Right" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <UniformGrid Margin="0,0,0,20" Columns="2">
                                        <StackPanel Margin="10">
                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="Productos más vendidos" />
                                            <lvc:CartesianChart
                                                x:Name="TopProductsBarHorizontalChart"
                                                Height="260"
                                                Margin="0,10,0,0" />
                                        </StackPanel>
                                        <StackPanel Margin="10">
                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="Ingresos por producto" />
                                            <lvc:CartesianChart
                                                x:Name="IncomeByProductBarChart"
                                                Height="220"
                                                Margin="0,10,0,0" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <UniformGrid Margin="0,0,0,20" Columns="2">
                                        <StackPanel Margin="10">
                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="Número de transacciones" />
                                            <lvc:CartesianChart
                                                x:Name="TransactionsCountByDayColumnChart"
                                                Height="220"
                                                Margin="0,10,0,0" />
                                        </StackPanel>
                                        <StackPanel Margin="10">
                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="Distribución de tamaño de compra" />
                                            <lvc:CartesianChart
                                                x:Name="PurchaseSizeHistogramChart"
                                                Height="220"
                                                Margin="0,10,0,0" />
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <Grid
            x:Name="NotificationContainer"
            Margin="20"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            IsHitTestVisible="False" />
    </Grid>
</Window>
